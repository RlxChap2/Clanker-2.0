# Clanker 2.0 environment variables
# The CLI can fill TOKEN automatically when you enter it.

TOKEN=

# Optional remote recovery commands.
# Enable only on your own bot/server.
CLANKER_REMOTE_RECOVERY=0
CLANKER_OWNER_IDS=
CLANKER_RECOVERY_PREFIX=!clanker

# Optional: override the recovered project root.
# If empty, the bot recovers the folder that contains index.js.
CLANKER_RECOVERY_ROOT=

# Optional safety limits.
CLANKER_RECOVERY_MAX_FILE_BYTES=1048576
CLANKER_RECOVERY_MAX_ARCHIVE_BYTES=8388608
CLANKER_RECOVERY_MAX_FILES=1200
CLANKER_RECOVERY_EXCLUDE_NAMES=
CLANKER_RECOVERY_EXCLUDE_EXTS=

# Optional: exit after the bot reaches ready state.
# Leave empty or 0 to keep the bot online.
CLANKER_AUTO_EXIT_AFTER_READY_MS=0
